# Required: Authentication token for API access
TOKEN=your-secret-token-here

# Optional: Server configuration
PORT=8080
LOG_LEVEL=info

# Optional: Size limits (in bytes)
MAX_REQUEST_BODY_SIZE=10485760    # 10MB
MAX_RESPONSE_BODY_SIZE=52428800   # 50MB

# Optional: Timeout configuration (in seconds)
MAX_TIMEOUT=120
DEFAULT_TIMEOUT=30

# Optional: CORS allowed origins (comma-separated, "*" for any)
CORS_ALLOWED_ORIGINS=*

# Optional: SSRF protection
# Allow requests to private/loopback/link-local addresses (default: false)
SSRF_ALLOW_PRIVATE=false
# Comma-separated hostnames to always block
# SSRF_DENY_HOSTS=
# Comma-separated allowlist; if set, only these hosts are permitted
# SSRF_ALLOW_HOSTS=
