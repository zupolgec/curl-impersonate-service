# Authentication: at least one of TOKEN or ADMIN_TOKEN is required.
# TOKEN is seeded as an API token (backward compatible). Additional tokens are
# managed from the admin UI.
TOKEN=your-secret-token-here

# Enables the admin UI at /admin/ (HTTP Basic auth, password = this token)
ADMIN_TOKEN=your-admin-token-here

# Datastore (SQLite) and usage-log retention
DATA_DIR=/data
LOG_RETENTION_HOURS=72

# Optional: Server configuration
PORT=8080
LOG_LEVEL=info

# Optional: Size limits (in bytes)
MAX_REQUEST_BODY_SIZE=10485760    # 10MB
MAX_RESPONSE_BODY_SIZE=52428800   # 50MB

# Optional: Timeout configuration (in seconds)
MAX_TIMEOUT=120
DEFAULT_TIMEOUT=30

# Optional: CORS allowed origins (comma-separated, "*" for any)
CORS_ALLOWED_ORIGINS=*

# Optional: SSRF protection
# Allow requests to private/loopback/link-local addresses (default: false)
SSRF_ALLOW_PRIVATE=false
# Allow plain http:// targets (default: false = https only)
SSRF_ALLOW_HTTP=false
# Allow targets addressed by raw IP (default: false = hostnames only)
SSRF_ALLOW_IP=false
# Comma-separated hostnames to always block
# SSRF_DENY_HOSTS=
# Comma-separated allowlist; if set, only these hosts are permitted
# SSRF_ALLOW_HOSTS=
